# Local production-style environment for PeakDecline.
# Replace placeholder values before running a public deployment.

FLASK_ENV=production
APP_HOST=127.0.0.1
PORT=9002

# From the old master branch config. Replace with a stronger generated value before public use.
SECRET_KEY=dev-key-replace-in-production

# Enable these when Caddy/Nginx terminates HTTPS in front of Flask.
TRUST_PROXY=true
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# Set this to the exact public origin users visit. Master used wildcard Socket.IO origins,
# but the deployment branch expects explicit origins for production.
# Example: https://watch.example.com
SOCKETIO_ALLOWED_ORIGINS=https://your-domain.example
SOCKETIO_ASYNC_MODE=eventlet

# Required for multi-process Socket.IO room state in production.
REDIS_URL=redis://127.0.0.1:6379/0

# Plex server reachable from the app server.
PLEX_URL=http://127.0.0.1:32400
PLEX_TOKEN=uHmJsmLp1jo-BxJKWQGU
PLEX_STREAM_MODE=caddy
PLEX_DIRECT_PLAY=true
PLEX_DIRECT_STREAM=true
PLEX_MAX_VIDEO_BITRATE=12000

# Password reset email settings.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=peakdecline@gmail.com
MAIL_PASSWORD=aspt mifz vjux izdw
MAIL_DEFAULT_SENDER=Peak Decline
